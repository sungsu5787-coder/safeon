# 카카오 알림톡
PORT=3000
KAKAO_API_KEY=YOUR_KAKAO_API_KEY
KAKAO_RECIPIENT_PHONE=+8210xxxxxxxx
KAKAO_API_URL=https://api.kakao.com/v1/alimtalk/send
KAKAO_TEMPLATE_ID=YOUR_TEMPLATE_ID

# Firebase Admin SDK (클라우드 배포 필수)
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# 다운로드한 JSON 파일을 base64로 인코딩하여 아래에 붙여넣기
# 인코딩 방법: cat firebase-service-account.json | base64 -w 0
FIREBASE_SERVICE_ACCOUNT=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
FIREBASE_STORAGE_BUCKET=samhwa-safeon.firebasestorage.app
